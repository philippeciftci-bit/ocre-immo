# M_GLITCHTIP_INSTALL — variables Docker Compose
# Copier en .env (mode 0600 root:root) + remplir SECRET_KEY + OVH_SMTP_PWD
# SECRET_KEY génère via : python3 -c "import secrets; print(secrets.token_urlsafe(50))"
# OVH_SMTP_PWD = contenu de /root/.secrets/ovh-noreply-ocre.pwd

SECRET_KEY=changeme-secret-key-50-chars-min
OVH_SMTP_PWD=changeme-ovh-noreply-pwd
